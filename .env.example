"""
ROXX AI - Environment Configuration Template
Part 1: Database Setup & User Model

Copy this file to .env and fill in your actual values
"""

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
# For Development (SQLite)
DEV_DATABASE_URL=sqlite:///roxx_dev.db

# For Production (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/roxx_prod
STAGING_DATABASE_URL=postgresql://user:password@localhost:5432/roxx_staging

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# AI/ML API Keys
OPENAI_API_KEY=sk-your-openai-api-key
REPLICATE_API_KEY=your-replicate-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com

# Email Configuration (for future use)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# AWS Configuration (for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/roxx.log

# Feature Flags
ENABLE_IMAGE_GENERATION=True
ENABLE_PHOTO_REPAIR=True
ENABLE_VIDEO_MAKER=True
ENABLE_VOICE_SYNTHESIS=True
ENABLE_AI_SINGER=True
ENABLE_GEMINI_CHAT=True

# Application Settings
MAX_UPLOAD_SIZE=104857600
DEFAULT_VOICE=boy
DEFAULT_THEME=light
